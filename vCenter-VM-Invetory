pipeline {
    agent { label 'rhel-agent' }

    environment {
        VC_SERVER = '10.10.121.25'
    }

    stages {

        stage('VM List from vCenter') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'vcenter-creds',
                        usernameVariable: 'VC_USER',
                        passwordVariable: 'VC_PASS'
                    )
                ]) {

                    sh '''
pwsh -NoProfile -Command "
\$ErrorActionPreference = 'Stop'

Write-Host '=== Starting PowerCLI Script ==='

Import-Module VMware.VimAutomation.Core -Force

Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:\$false | Out-Null
Set-PowerCLIConfiguration -Scope User -ParticipateInCEIP \$false -Confirm:\$false | Out-Null

Write-Host 'Connecting to vCenter...'

\$securePass = ConvertTo-SecureString \$env:VC_PASS -AsPlainText -Force
\$cred = New-Object System.Management.Automation.PSCredential(\$env:VC_USER, \$securePass)

Connect-VIServer -Server \$env:VC_SERVER -Credential \$cred

Write-Host 'Fetching VM inventory...'

Get-VM |
Select-Object Name, PowerState, NumCpu, MemoryGB |
Export-Csv '$WORKSPACE/vcenter_vm_list.csv' -NoTypeInformation

Write-Host 'Disconnecting from vCenter...'
Disconnect-VIServer * -Confirm:\$false

Write-Host 'CSV file generated successfully.'
"
'''
                }
            }
        }
    }

    post {

        success {

            archiveArtifacts artifacts: 'vcenter_vm_list.csv'

            emailext(
                to: 'abdul.muqtadir@ctrls.in',
                subject: "vCenter VM Inventory Report - ${JOB_NAME} #${BUILD_NUMBER}",
                body: """
Hi Team,

The vCenter VM inventory job completed successfully.

Job Name: ${JOB_NAME}
Build Number: ${BUILD_NUMBER}

Please find the attached VM inventory report.

Regards,
Jenkins
""",
                attachmentsPattern: 'vcenter_vm_list.csv'
            )
        }

        failure {

            emailext(
                to: 'abdul.muqtadir@ctrls.in',
                subject: "FAILED - ${JOB_NAME} #${BUILD_NUMBER}",
                body: """
Hi Team,

The vCenter VM inventory job has failed.

Job Name: ${JOB_NAME}
Build Number: ${BUILD_NUMBER}

Please check the Jenkins console output for details.

Build URL:
${BUILD_URL}

Regards,
Jenkins
"""
            )
        }
    }
}
