pipeline {
    agent any

    environment {
        VC_SERVER = "10.10.121.25"
    }

    stages {

        stage('VM Inventory from vCenter') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'vcenter-creds',
                        usernameVariable: 'VC_USER',
                        passwordVariable: 'VC_PASS'
                    )
                ]) {

                    sh '''
                    pwsh -NoProfile -ExecutionPolicy Bypass -File vCenter-VM-Inventory.ps1
                    '''
                }
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: 'vcenter_vm_list.csv', fingerprint: true

            emailext(
                to: 'tauqeer.mohammed@ctrls.in',
                subject: "VM list for Gamut",
                body: """
Hi Tauqeer,

Please find the attached VM list of Gamut customer.

This is for testing purpose.

Regards,
Abdul Muqtadir
""",
                attachmentsPattern: 'vcenter_vm_list.csv'
            )
        }

        failure {
            emailext(
                to: 'abdul.muqtadir@ctrls.in',
                subject: "FAILED VM Inventory - ${JOB_NAME}",
                body: "Job failed. Please check Jenkins logs."
            )
        }
    }
}
