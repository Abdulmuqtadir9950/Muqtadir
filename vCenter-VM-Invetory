pipeline {
    agent any

    environment {
        VC_SERVER = "10.10.121.25"
    }

    stages {
        stage('VM List from vCenter') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'vcenter-creds',
                    usernameVariable: 'VC_USER',
                    passwordVariable: 'VC_PASS'
                )]) {

                    sh '''
                    pwsh -NoProfile -File vCenter-VM-Invetory.ps1
                    '''
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'vcenter_vm_list.csv', allowEmptyArchive: true

            emailext(
                to: 'abdul.muqtadir@ctrls.in',
                subject: "VM Report - ${JOB_NAME} #${BUILD_NUMBER}",
                body: "VM inventory completed. Please find attached report.",
                attachmentsPattern: 'vcenter_vm_list.csv'
            )
        }
    }
}
