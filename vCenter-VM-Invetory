pipeline {
    agent any

    environment {
        VC_SERVER = "10.10.121.25"
    }

    stages {

        stage('VM Inventory') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'vcenter-creds',
                    usernameVariable: 'VC_USER',
                    passwordVariable: 'VC_PASS'
                )]) {

                    sh '''
                    pwsh -NoProfile -ExecutionPolicy Bypass -File vCenter-VM-Inventory.ps1
                    '''
                }
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: 'vcenter_vm_list.csv'

            emailext (
                to: 'abdul.muqtadir@ctrls.in',
                subject: "VM Report - ${JOB_NAME} #${BUILD_NUMBER}",
                body: "VM inventory generated successfully.",
                attachmentsPattern: 'vcenter_vm_list.csv'
            )
        }
    }
}
