pipeline {
    agent any

    environment {
        VC_SERVER = "10.10.121.25"
    }

    stages {
        stage('VM Inventory') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'vcenter-creds',
                    usernameVariable: 'VC_USER',
                    passwordVariable: 'VC_PASS'
                )]) {

                    sh '''
                    pwsh -NoProfile -ExecutionPolicy Bypass -File vCenter-VM-Invetory.ps1
                    '''
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'vcenter_vm_list.csv', allowEmptyArchive: true
        }
    }
}
