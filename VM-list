pipeline {
    agent { label 'windows-agent' }

    environment {
        VC_SERVER = "10.10.121.25"
    }

    stages {

        stage('VM List from vCenter') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'vcenter-creds',
                        usernameVariable: 'VC_USER',
                        passwordVariable: 'VC_PASS'
                    )
                ]) {

                    powershell '''
                    $ErrorActionPreference = "Stop"

                    Write-Host "=== Starting PowerCLI Script ==="

                    Set-ExecutionPolicy -Scope Process Bypass -Force

                    $env:PSModulePath += ";C:\\Users\\Administrator\\Documents\\WindowsPowerShell\\Modules"

                    Import-Module VMware.VimAutomation.Core -Force

                    Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:$false | Out-Null

                    # Disable CEIP warning permanently (optional)
                    Set-PowerCLIConfiguration -Scope User -ParticipateInCEIP $false -Confirm:$false | Out-Null

                    Write-Host "Connecting to vCenter: $env:VC_SERVER"

                    $securePass = ConvertTo-SecureString $env:VC_PASS -AsPlainText -Force
                    $cred = New-Object System.Management.Automation.PSCredential ($env:VC_USER, $securePass)

                    Connect-VIServer -Server $env:VC_SERVER -Credential $cred

                    Write-Host "Fetching VM list..."

                    $vms = Get-VM

                    $vms | Select Name, PowerState, NumCpu, MemoryGB | Format-Table -AutoSize

                    $vms | Select Name, PowerState, NumCpu, MemoryGB |
                        Export-Csv "$env:WORKSPACE\\vcenter_vm_list.csv" -NoTypeInformation

                    Write-Host "Disconnecting..."
                    Disconnect-VIServer * -Confirm:$false

                    Write-Host "DONE - CSV generated"
                    '''
                }
            }
        }
    }

    post {
    always {
        archiveArtifacts artifacts: 'vcenter_vm_list.csv', onlyIfSuccessful: true

        emailext (
            to: 'abdul.muqtadir@ctrls.in',
            subject: "VM List Report - ${JOB_NAME} - Build #${BUILD_NUMBER}",
            body: """
            Hi Team,

            VM inventory job has completed.

            Job: ${JOB_NAME}
            Build Number: ${BUILD_NUMBER}

            Please find the attached VM list report.

            Regards,
            Jenkins
            """,
            attachmentsPattern: 'vcenter_vm_list.csv'
        )
    }
}
